# 应用配置
APP_NAME=Video Subtitle OCR Service
APP_VERSION=1.0.0
DEBUG=false

# OCR配置
PADDLEOCR_USE_ANGLE_CLS=true
PADDLEOCR_LANG=ch
PADDLEOCR_USE_GPU=false
PADDLEOCR_DET_DB_THRESH=0.3
PADDLEOCR_DET_DB_BOX_THRESH=0.5

# 视频处理配置
VIDEO_SAMPLE_INTERVAL=1.0
VIDEO_MAX_DURATION=3600

# 字幕检测配置
SUBTITLE_DETECTION_SAMPLE_RATE=10
SUBTITLE_MIN_CONFIDENCE=0.7
SUBTITLE_ROI_BOTTOM_RATIO=0.35
SUBTITLE_MERGE_THRESHOLD=0.8
SUBTITLE_TIME_TOLERANCE=0.5

# 文件存储配置
UPLOAD_DIR=/tmp/uploads
OUTPUT_DIR=/tmp/outputs
MAX_UPLOAD_SIZE=524288000

# 服务配置
HOST=0.0.0.0
PORT=8000